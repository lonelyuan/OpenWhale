# OpenWhale 环境变量配置
# 复制此文件为 .env 并填写实际值

# ========== 必填配置 ==========

# 比赛平台 AGENT_TOKEN（用于 MCP 鉴权）
AGENT_TOKEN=your-agent-token-here

# 比赛平台 SERVER_HOST（不含 /mcp）
# 示例: 10.0.169.16 或 challenge.example.com
SERVER_HOST=your-server-host

# 竞赛 MCP 服务器地址
# 可选。若未设置，将根据 SERVER_HOST 自动拼接为 http://<SERVER_HOST>/mcp
MCP_SERVER_URL=

# TokenHub OpenAI 兼容接口 API Key（用于主智能体和测试脚本）
# 示例 Base URL: https://tokenhub.tencentmaas.com/v1
TOKENHUB_API_KEY=your-tokenhub-api-key-here

# ========== 可选配置 ==========

# 智能体基座（默认: openai_compat）
# 可选: openai_compat, openai, minimax, chat_completions
AGENT_BACKEND=openai_compat

# OpenAI 兼容模型配置（默认: MiniMax-M2.7）
MODEL_BASE_URL=https://tokenhub.tencentmaas.com/v1
MODEL_NAME=MiniMax-M2.7
MODEL_ID=ep-jsc7o0kw

# 日志级别（默认: INFO）
# 可选: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Web 界面配置
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8080
