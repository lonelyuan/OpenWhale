# OpenWhale 环境变量配置
# 复制此文件为 .env 并填写实际值

# ========== 必填配置 ==========

# Anthropic API Key（Claude 模型访问密钥）
# 获取地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# 竞赛 MCP 服务器地址
# 格式: http://<SERVER_HOST>/mcp
MCP_SERVER_URL=http://your-mcp-server-host/mcp

# ========== 可选配置 ==========

# Claude 模型（默认: claude-opus-4-5）
# 可选: claude-opus-4-5, claude-sonnet-4-5, claude-haiku-4-5
CLAUDE_MODEL=claude-opus-4-5

# 日志级别（默认: INFO）
# 可选: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Web 界面配置
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8080
