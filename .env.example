# OpenWhale 环境变量配置
# 复制此文件为 .env 并填写实际值

# ========== 必填配置 ==========

# 比赛平台 AGENT_TOKEN（用于 MCP 鉴权）
AGENT_TOKEN=your-agent-token-here

# 比赛平台 SERVER_HOST（不含 /mcp）
# 示例: 10.0.169.16 或 challenge.example.com
SERVER_HOST=your-server-host

# 竞赛 MCP 服务器地址
# 可选。若未设置，将根据 SERVER_HOST 自动拼接为 http://<SERVER_HOST>/mcp
MCP_SERVER_URL=

# TokenHub OpenAI 兼容接口 API Key（用于主智能体和测试脚本）
# 示例 Base URL: https://tokenhub.tencentmaas.com/v1
TOKENHUB_API_KEY=your-tokenhub-api-key-here

# ========== 可选配置 ==========

# 智能体基座（默认: openai_compat）
# 可选: openai_compat, openai, minimax, chat_completions, deepagents, claude_code
AGENT_BACKEND=openai_compat

# OpenAI 兼容模型配置（默认: MiniMax-M2.7）
MODEL_BASE_URL=https://tokenhub.tencentmaas.com/v1
MODEL_NAME=MiniMax-M2.7
MODEL_ID=ep-jsc7o0kw

# DeepAgents 后端说明
# 使用 AGENT_BACKEND=deepagents 时，会复用上面的 MODEL_* 与 TOKENHUB_API_KEY 配置。
# DeepAgents 运行保护（防止长时间循环）
# 最大递归步数（复用 MAX_ITERATIONS 的概念，默认来自代码中的 max_iterations）
# DeepAgents 图递归上限（默认 64，建议比 max_iterations 大很多）
DEEPAGENTS_RECURSION_LIMIT=64
# 单次运行超时秒数（默认 300）
DEEPAGENTS_TIMEOUT_SECONDS=300
# 相同工具+参数重复调用上限（默认 4，超过后将返回提醒并阻断真实调用）
DEEPAGENTS_REPEAT_CALL_LIMIT=4
# Bash 工具命令超时秒数（默认 120）
DEEPAGENTS_BASH_TIMEOUT_SECONDS=120
# Bash 工具输出截断字符数（默认 8000）
DEEPAGENTS_BASH_MAX_OUTPUT_CHARS=8000
# 是否输出 trace 阶段日志（默认 false，关闭后仅保留工具与助手关键信息）
DEEPAGENTS_TRACE_ENABLED=false
# 是否输出更细的事件流（默认 false；开启后会看到更多原始流式片段）
DEEPAGENTS_TRACE_VERBOSE=false

# Claude Code SDK 配置（切换 AGENT_BACKEND=claude_code 时使用）
# 默认沿用 MODEL_ID（即 MiniMax 模型 ID）
CLAUDE_MODEL=ep-jsc7o0kw
# 可选：指定 Claude Code CLI 路径；留空则使用 SDK 默认
CLAUDE_CLI_PATH=

# Claude 专用鉴权/网关（可选；留空则回退到 MODEL_API_KEY / MODEL_BASE_URL）
CLAUDE_API_KEY=
CLAUDE_BASE_URL=

# Claude Code 工具与权限管理
# MCP 主挑战服务器名称（会生成 mcp__<name>__* 的默认允许工具）
CHALLENGE_MCP_SERVER_NAME=challenge
# 工具集合预设（通常保持 claude_code）
CLAUDE_TOOLS_PRESET=claude_code
# 权限模式：default/acceptEdits/plan/bypassPermissions/dontAsk/auto
CLAUDE_PERMISSION_MODE=bypassPermissions
# 可选：覆盖默认允许工具列表（逗号分隔），例如 Bash,mcp__challenge__list_challenges
CLAUDE_ALLOWED_TOOLS=
# 可选：禁用工具列表（逗号分隔）
CLAUDE_DISALLOWED_TOOLS=

# 可选：接入额外 MCP 服务器（用于 RAG、扫描器等）
# 方式一：直接 JSON 字符串（对象）
EXTRA_MCP_SERVERS_JSON=
# 方式二：JSON 文件路径（对象）
EXTRA_MCP_SERVERS_FILE=

# 注意：Claude Code SDK 会校验模型名，通常不接受 OpenAI 风格模型标识（如 ep-***、MiniMax-***）。
# 若你要调用 MiniMax（OpenAI 接口），建议使用 AGENT_BACKEND=openai_compat 或 deepagents。

# 日志级别（默认: INFO）
# 可选: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Web 界面配置
WEB_ENABLED=true
WEB_HOST=0.0.0.0
WEB_PORT=8080

# ========== 离线持续运行（延时遥控脚本） ==========
# 首轮启动前延时秒数（默认 60）
AUTOPILOT_START_DELAY_SECONDS=60
# 每轮智能体运行完成后，下一轮开始前等待秒数（默认 5）
AUTOPILOT_CYCLE_INTERVAL_SECONDS=5
# 最大轮次（0 表示不限，直到全部题目完成）
AUTOPILOT_MAX_CYCLES=0
# 每轮执行的智能体命令
AUTOPILOT_AGENT_COMMAND=uv run openwhale
